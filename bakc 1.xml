  @Delete(':orderId')
  deleteOrder(
    @Param('restaurantId', ParseIntPipe) restaurantId: number,
    @Param('orderId') orderId: string,
    @Req() request: AuthenticatedRequest,
  ) {
    return this.ordersService.deleteOrder(
      restaurantId,
      orderId,
      request.user.id,
    );
  }
}
