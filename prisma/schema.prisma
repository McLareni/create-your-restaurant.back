generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int          @id @default(autoincrement())
  email              String       @unique
  firstName          String?
  lastName           String?
  photo              String?
  role               EnumRole
  createdAt          DateTime     @default(now())
  loginCodeExpiresAt DateTime?
  loginCodeHash      String?
  restaurants        Restaurant[]
  sessions           Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Restaurant {
  id             Int                @id @default(autoincrement())
  title          String
  slug           String             @unique
  type           EnumTypeRestaurant
  currency       EnumCurrency
  phoneNumber    String?
  city           String?
  language       EnumLanguage
  ownerId        Int
  categories     Category[]
  DiningTable    DiningTable[]
  modifierGroups ModifierGroup[]
  combos         Combo[]
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  staff          Staff[]
  orders         Order[]
}

model Image {
  id          String      @id @default(uuid())
  url         String
  createdAt   DateTime    @default(now())
  imageDishes ImageDish[]
}

model ImageDish {
  id      String @id @default(uuid())
  dishId  String
  imageId String
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)
}

model Category {
  id           String     @id @default(uuid())
  restaurantId Int
  name         String
  sortOrder    Int        @default(0)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       Dish[]
}

model Dish {
  id            String           @id @default(uuid())
  categoryId    String
  name          String
  description   String?
  price         Float
  weight        Float?           
  cookingTime   Int?             
  calories      Int?             
  isVegan       Boolean          @default(false)
  isSpicy       Boolean          @default(false)
  isLactoseFree Boolean          @default(false)
  badge         BadgeType        @default(NONE)
  allergens     String[]
  tags          String[]
  taxRate       Float            @default(0)
  isAvailable   Boolean          @default(true)
  sortOrder     Int              @default(0)
  category      Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifiers     DishModifier[]
  images        ImageDish[]
  ingredients   DishIngredient[]
  orderItems    OrderItem[]
  variants      DishVariant[]    
  comboDishes   ComboDish[]

  upsellTo      DishUpsell[]     @relation("MainDishRelation")
  upselledBy    DishUpsell[]     @relation("UpsellDishRelation")

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt @default(now())
}

model DishVariant {
  id        String   @id @default(uuid())
  dishId    String
  name      String
  price     Float
  sku       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model DishIngredient {
  id       String @id @default(uuid())
  dishId   String
  name     String
  quantity Float
  unit     String
  dish     Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model DishUpsell {
  mainDishId   String
  upsellDishId String
  mainDish     Dish   @relation("MainDishRelation", fields: [mainDishId], references: [id], onDelete: Cascade)
  upsellDish   Dish   @relation("UpsellDishRelation", fields: [upsellDishId], references: [id], onDelete: Cascade)

  @@id([mainDishId, upsellDishId])
}

model Combo {
  id           String         @id @default(uuid())
  restaurantId Int
  name         String
  priceType    ComboPriceType
  priceValue   Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       ComboDish[]
}

model ComboDish {
  id      String @id @default(uuid())
  comboId String
  dishId  String
  name    String
  price   Float
  combo   Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model Staff {
  id           String     @id @default(uuid())
  restaurantId Int
  firstName    String
  lastName     String?
  email        String
  phone        String?
  role         String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ModifierGroup {
  id            String           @id @default(uuid())
  restaurantId  Int
  name          String
  isRequired    Boolean          @default(false)
  minSelections Int              @default(0)
  maxSelections Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  dishes        DishModifier[]
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  options       ModifierOption[]
}

model ModifierOption {
  id              String        @id @default(uuid())
  modifierGroupId String
  name            String
  price           Float         @default(0)
  isAvailable     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  group           ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]
}

model DishModifier {
  dishId          String
  modifierGroupId String
  dish            Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([dishId, modifierGroupId])
}

model DiningTable {
  id           String      @id
  restaurantId Int
  number       Int
  status       TableStatus @default(ACTIVE)
  type         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@unique([restaurantId, number])
}

model Order {
  id          String       @id @default(uuid())
  restaurantId Int
  tableId     String?
  type        OrderType    @default(DINE_IN)
  status      OrderStatus  @default(PENDING)
  totalAmount Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table       DiningTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items       OrderItem[]

  @@index([restaurantId, status])
  @@index([tableId])
}

model OrderItem {
  id        String              @id @default(uuid())
  orderId   String
  dishId    String
  quantity  Int
  unitPrice Float
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish      Dish                @relation(fields: [dishId], references: [id], onDelete: Restrict)
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([dishId])
}

model OrderItemModifier {
  id               String         @id @default(uuid())
  orderItemId      String
  modifierOptionId String
  quantity         Int            @default(1)
  unitPrice        Float
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Restrict)

  @@unique([orderItemId, modifierOptionId])
  @@index([orderItemId])
  @@index([modifierOptionId])
}

enum EnumRole {
  OWNER
  STAFF
  CUSTOMER
}

enum EnumLanguage {
  EN
  FR
  ES
  DE
  IT
  RU
  CN
  JP
  PL
  UA
}

enum EnumCurrency {
  USD
  EUR
  GBP
  JPY
  CNY
  RUB
  PLN
  UAH
}

enum EnumTypeRestaurant {
  FAST_FOOD
  CASUAL_DINING
  FINE_DINING
  CAFE
  BUFFET
  FOOD_TRUCK
}

enum BadgeType {
  NONE
  NEW
  HIT
  CHEF_CHOICE
  TOP_RATED
}

enum TableStatus {
  ACTIVE
  INACTIVE
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  READY
  COMPLETED
  CANCELED
}

enum ComboPriceType {
  FIXED
  DISCOUNT
}