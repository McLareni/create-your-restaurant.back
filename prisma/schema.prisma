datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  STAFF
}

enum StaffRole {
  MANAGER
  WAITER
  CHEF
  BARTENDER
}

enum RestaurantType {
  FAST_FOOD
  CASUAL_DINING
  FINE_DINING
  CAFE
  BUFFET
  FOOD_TRUCK
}

enum Currency {
  USD
  EUR
  GBP
  JPY
  CNY
  RUB
  PLN
  UAH
}

enum Language {
  EN
  ES
  FR
  DE
  IT
  ZH
  JA
  RU
  PL
  UA
}

enum DishBadge {
  NONE
  NEW
  HIT
  CHEF_CHOICE
  TOP_RATED
}

enum ProductionZone {
  NONE
  HOT_KITCHEN
  COLD_KITCHEN
  BAR
  SUSHI
  HOOKAH
}

enum TableStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COOKING
  READY
  DELIVERED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String
  lastName  String?
  photo     String?
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants Restaurant[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginCode {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Restaurant {
  id          Int            @id @default(autoincrement())
  ownerId     Int
  user        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  slug        String         @unique
  type        RestaurantType
  currency    Currency       @default(UAH)
  phoneNumber String?
  city        String?
  language    Language       @default(UA)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  categories     Category[]
  staff          Staff[]
  modifierGroups ModifierGroup[]
  combos         Combo[]
  tables         DiningTable[]
  orders         Order[]
}

model Staff {
  id           String     @id @default(uuid())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String?
  email        String     @unique
  phone        String?
  role         StaffRole  @default(WAITER)
  isActive     Boolean    @default(true)
  photo        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id           String     @id @default(uuid())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  dishes Dish[]

  @@unique([restaurantId, name])
}

model Dish {
  id           String         @id @default(uuid())
  categoryId   String
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float
  taxRate      Float          @default(20.0)
  weight       Float?
  cookingTime  Int?
  calories     Int?
  isVegan      Boolean        @default(false)
  isSpicy      Boolean        @default(false)
  isLactoseFree Boolean       @default(false)
  badge        DishBadge      @default(NONE)
  allergens    String[]       @default([])
  tags         String[]       @default([])
  isAvailable  Boolean        @default(true)
  stockQuantity Int?
  productionZone ProductionZone @default(NONE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  variants         DishVariant[]
  ingredients      IngredientItem[]
  modifierRelation DishModifier[]
  comboRelation    ComboDish[]
  images           DishImage[]
  orderItems       OrderItem[]
}

model DishVariant {
  id        String   @id @default(uuid())
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  sku       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngredientItem {
  id        String   @id @default(uuid())
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float
  unit      String   @default("г")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModifierGroup {
  id            String     @id @default(uuid())
  restaurantId  Int
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  isRequired    Boolean    @default(false)
  minSelections Int        @default(0)
  maxSelections Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  options fontModifierOption[]
  dishRelation DishModifier[]
}

model fontModifierOption {
  id              String        @id @default(uuid())
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String
  price           Float         @default(0.0)
  isAvailable     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model DishModifier {
  dishId          String
  dish            Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([dishId, modifierGroupId])
}

model Combo {
  id           String     @id @default(uuid())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  priceType    String     @default("FIXED")
  priceValue   Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  dishes ComboDish[]
}

model ComboDish {
  comboId String
  combo   Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  dishId  String
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@id([comboId, dishId])
}

model ImageAsset {
  id        String   @id @default(uuid())
  url       String
  publicId  String?
  createdAt DateTime @default(now())

  dishRelation DishImage[]
}

model DishImage {
  dishId  String
  dish    Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  imageId String
  image   ImageAsset @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([dishId, imageId])
}

model DiningTable {
  id           String      @id @default(uuid())
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  number       Int
  type         String?
  status       TableStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]

  @@unique([restaurantId, number])
}

model Order {
  id           String      @id @default(uuid())
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        DiningTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  status       OrderStatus @default(PENDING)
  type         OrderType   @default(DINE_IN)
  totalAmount  Float
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items        OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
}